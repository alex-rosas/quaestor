# Quaestor — Environment Configuration
# Copy this file to .env and fill in your actual values.
# All fields have safe defaults; you only NEED an API key for your chosen LLM provider.

# =============================================================================
# LLM Provider
# =============================================================================

# Which LLM backend to use. Options: groq | ollama | together
# Default: groq (recommended — free tier, 300 tok/s)
LLM_PROVIDER=groq

# LLM generation parameters (apply to all providers)
LLM_TEMPERATURE=0.0
LLM_MAX_TOKENS=1024

# =============================================================================
# Groq (recommended — free tier at https://console.groq.com)
# =============================================================================

# Required when LLM_PROVIDER=groq
GROQ_API_KEY=your_groq_api_key_here

GROQ_MODEL=llama-3.3-70b-versatile

# =============================================================================
# Ollama (local inference, no API key required)
# =============================================================================

# Required when LLM_PROVIDER=ollama or EMBEDDING_PROVIDER=ollama
# Default assumes Ollama running on localhost
OLLAMA_BASE_URL=http://localhost:11434

OLLAMA_LLM_MODEL=llama3.1:8b

# =============================================================================
# Together.ai (cloud fallback — https://api.together.xyz)
# =============================================================================

# Required when LLM_PROVIDER=together
TOGETHER_API_KEY=your_together_api_key_here

TOGETHER_MODEL=meta-llama/Meta-Llama-3.1-70B-Instruct-Turbo

# =============================================================================
# Embeddings
# =============================================================================

# Which embedding backend to use. Options: ollama | huggingface
# Default: ollama (local, zero cost, M1-compatible with nomic-embed-text)
EMBEDDING_PROVIDER=ollama

# Ollama embedding model (used when EMBEDDING_PROVIDER=ollama)
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# HuggingFace embedding model (used when EMBEDDING_PROVIDER=huggingface)
HUGGINGFACE_EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# =============================================================================
# Vector Store (ChromaDB)
# =============================================================================

# Directory where ChromaDB persists its data (git-ignored)
CHROMA_PERSIST_DIR=.chroma

# ChromaDB collection name
CHROMA_COLLECTION_NAME=quaestor

# =============================================================================
# Chunking (Phase 1 baseline — fixed-size)
# =============================================================================

# Token count per chunk. Must be > 0.
CHUNK_SIZE=512

# Token overlap between consecutive chunks. Must be < CHUNK_SIZE.
CHUNK_OVERLAP=50

# =============================================================================
# Retrieval
# =============================================================================

# Number of chunks to retrieve per query
RETRIEVAL_TOP_K=5

# =============================================================================
# Data Paths (git-ignored directories)
# =============================================================================

# Raw source documents (downloaded SEC filings, uploaded PDFs)
DATA_RAW_DIR=data/raw

# Processed / chunked documents
DATA_PROCESSED_DIR=data/processed

# =============================================================================
# SEC EDGAR Downloader
# =============================================================================

# Name and email sent in the SEC EDGAR User-Agent header.
# Required only if you use the "Load SEC Filing" sidebar option.
# SEC policy: must identify yourself — use your real name and email.
SEC_REQUESTER_NAME=Your Name
SEC_REQUESTER_EMAIL=your@email.com
