# Quaestor Phase 1 Baseline - Environment Configuration
# Copy this file to .env and fill in your actual values

# === LLM Provider Configuration ===
# Options: "groq", "ollama", "together"
LLM_PROVIDER=groq

# Groq API key (get free tier at https://console.groq.com)
# Required if LLM_PROVIDER=groq
GROQ_API_KEY=your_groq_api_key_here

# Ollama base URL (required if LLM_PROVIDER=ollama)
# Default assumes Ollama running locally
OLLAMA_BASE_URL=http://localhost:11434

# Together.ai API key (required if LLM_PROVIDER=together)
TOGETHER_API_KEY=your_together_api_key_here

# === Chunking Configuration ===
# Phase 1 uses fixed-size chunking - these values are frozen
CHUNK_SIZE=512
CHUNK_OVERLAP=50

# === Vector Store Configuration ===
COLLECTION_NAME=quaestor
CHROMA_PERSIST_DIR=.chroma
TOP_K=5

# === Model Names (Phase 1 frozen values) ===
# Groq model
GROQ_MODEL=llama-3.3-70b-versatile

# Ollama models
OLLAMA_LLM_MODEL=llama3.1:8b
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# Together.ai model
TOGETHER_MODEL=meta-llama/Meta-Llama-3.1-70B-Instruct-Turbo
