# Python-generated files
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info

# Virtual environments
.venv
.env
__pycache__/
.chroma/
data/raw/

# Claude Code
genesis/

# Benchmarks - results only, not raw data
benchmarks/*.csv
benchmarks/*.parquet
!benchmarks/*.json

# Keep docs/ clean
docs/**/.DS_Store
docs/**/*.tmp

# macOS metadata
.DS_Store
**/.DS_Store

# Python cache (more aggressive pattern)
**/__pycache__/
**/*.pyc
**/*.pyo

# Temporary files
migration-status.txt

# Notebooks - commit the notebooks, ignore generated data and checkpoints
notebooks/data/
.ipynb_checkpoints/

# Data directories - structure only, never commit actual data
data/**/*
!data/.gitkeep
!data/processed/.gitkeep

# docs/ — ignored until final documentation phase
docs/

# Baseline runtime artifacts
examples/phase1-baseline/data/
examples/phase1-baseline/.chroma/
examples/phase1-baseline/.venv/
examples/phase1-baseline/.tmp_uploads/

